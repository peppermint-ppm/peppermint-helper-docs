---
import config from 'virtual:starlight/user-config';
import Search from 'virtual:starlight/components/Search';
import Sidebar from 'virtual:starlight/components/Sidebar';
import { Menu, Moon, Sparkle, SunMedium, X } from '@lucide/astro';
import peppermintLogoDark from '../assets/peppermint-logo-dark.svg';

const shouldRenderSearch =
  config.pagefind || config.components.Search !== '@astrojs/starlight/components/Search.astro';
const { hasSidebar } = Astro.locals.starlightRoute;
---

<div class="app-header-inner flex h-full w-full flex-nowrap items-center justify-between gap-2 min-[1280px]:gap-3">
  <div class="app-header-brand flex min-w-0 items-center gap-3 min-[1280px]:gap-5">
    <a href="/" class="shrink-0" aria-label="Peppermint home">
      <img src="/peppermint-logo.svg" alt="Peppermint" class="header-wordmark header-wordmark--light h-8 w-auto min-[1280px]:h-10" />
      <img src={peppermintLogoDark.src} alt="Peppermint" class="header-wordmark header-wordmark--dark h-8 w-auto min-[1280px]:h-10" />
    </a>
    <a href="/" class="app-header-help-tag shrink-0 whitespace-nowrap text-[15px] leading-[23px] font-medium no-underline rounded-sm flex gap-0.5 justify-center items-center py-0.5 pl-1.5 pr-1.5"><Sparkle stroke-width={1.6} fill="currentColor" class="w-2.5 h-2.5 shrink-0" /> Help</a>
  </div>

  <div class="app-header-search-desktop hidden min-w-0 min-[1280px]:flex print:hidden">
    {shouldRenderSearch && <Search />}
  </div>

  <div class="app-header-end flex shrink-0 items-center gap-2 min-[1280px]:gap-5 print:hidden">
    <div class="app-header-actions-desktop hidden min-[1280px]:flex items-center gap-5">
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <SunMedium id="theme-icon-light" stroke-width={1.6} class="h-6 w-6" />
        <Moon id="theme-icon-dark" stroke-width={1.6} class="hidden h-6 w-6" />
      </button>
      <a
        href="https://www.runpeppermint.com/dashboard"
        class="app-header-dashboard-desktop inline-flex items-center text-white text-[16px] leading-[24px] font-medium whitespace-nowrap rounded-sm border border-(--app-primary) bg-(--app-primary) px-4 py-2 no-underline cursor-pointer transition-colors duration-150 hover:bg-(--app-primary-hover) [box-shadow:0px_1px_1px_0px_var(--app-button-shadow-1),0px_2px_5px_0px_var(--app-button-shadow-2),inset_0px_-1px_1px_0px_var(--app-button-shadow-inset)]"
      >
        Go to Dashboard
      </a>
    </div>

    <div class="app-header-actions-compact flex min-[1280px]:hidden items-center gap-2">
      <button
        id="theme-toggle-compact"
        type="button"
        class="text-(--app-text-subtle)"
        aria-label="Toggle theme"
        title="Toggle theme"
      >
        <SunMedium id="theme-icon-light-compact" stroke-width={1.6} class="h-6 w-6" />
        <Moon id="theme-icon-dark-compact" stroke-width={1.6} class="hidden h-6 w-6" />
      </button>
      {hasSidebar ? (
        <button
          id="app-header-menu-toggle"
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-sm border border-(--app-border) text-(--app-text-subtle)"
          aria-label="Open menu"
          aria-controls="starlight__sidebar"
          aria-expanded="false"
        >
          <Menu stroke-width={1.6} class="open-icon h-6 w-6" aria-hidden="true" />
          <X stroke-width={1.6} class="close-icon hidden h-6 w-6" aria-hidden="true" />
        </button>
      ) : (
        <button
          id="app-homepage-menu-toggle"
          type="button"
          class="inline-flex h-9 w-9 items-center justify-center rounded-sm border border-(--app-border) text-(--app-text-subtle)"
          aria-label="Open menu"
          aria-controls="app-homepage-menu"
          aria-expanded="false"
        >
          <Menu stroke-width={1.6} class="open-icon h-6 w-6" aria-hidden="true" />
          <X stroke-width={1.6} class="close-icon hidden h-6 w-6" aria-hidden="true" />
        </button>
      )}
    </div>
  </div>
</div>

{!hasSidebar && (
  <div id="app-homepage-menu" class="app-homepage-menu" hidden>
    <Sidebar />
  </div>
)}

<script is:inline>
  const storageKey = 'starlight-theme';
  const prefersLight = matchMedia('(prefers-color-scheme: light)');

  const getPreferredColorScheme = () => (prefersLight.matches ? 'light' : 'dark');
  const parseTheme = (theme) => (theme === 'dark' || theme === 'light' || theme === 'auto' ? theme : 'auto');
  const loadTheme = () => parseTheme(localStorage.getItem(storageKey));
  const appliedTheme = () => {
    const theme = loadTheme();
    return theme === 'auto' ? getPreferredColorScheme() : theme;
  };

  const lightIcon = document.getElementById('theme-icon-light');
  const darkIcon = document.getElementById('theme-icon-dark');
  const toggle = document.getElementById('theme-toggle');
  const lightIconCompact = document.getElementById('theme-icon-light-compact');
  const darkIconCompact = document.getElementById('theme-icon-dark-compact');
  const toggleCompact = document.getElementById('theme-toggle-compact');
  const header = document.querySelector('.page > .header');

  const syncIcons = (theme) => {
    lightIcon?.classList.toggle('hidden', theme === 'dark');
    darkIcon?.classList.toggle('hidden', theme !== 'dark');
    lightIconCompact?.classList.toggle('hidden', theme === 'dark');
    darkIconCompact?.classList.toggle('hidden', theme !== 'dark');
  };

  const applyTheme = (theme) => {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem(storageKey, theme);
    window.StarlightThemeProvider?.updatePickers(theme);
    syncIcons(theme);
  };

  const initialTheme = appliedTheme();
  document.documentElement.dataset.theme = initialTheme;
  syncIcons(initialTheme);

  const onThemeClick = () => {
    const nextTheme = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
    applyTheme(nextTheme);
  };

  toggle?.addEventListener('click', onThemeClick);
  toggleCompact?.addEventListener('click', onThemeClick);

  const syncScrolledHeader = () => {
    header?.classList.toggle('is-scrolled', window.scrollY > 0);
  };

  syncScrolledHeader();
  window.addEventListener('scroll', syncScrolledHeader, { passive: true });

  // Docs pages: trigger native Starlight sidebar
  const menuToggle = document.getElementById('app-header-menu-toggle');

  const setSidebarExpanded = (expanded) => {
    const starlightMenuBtn = document.querySelector('starlight-menu-button');
    if (!starlightMenuBtn) return;
    starlightMenuBtn.setAttribute('aria-expanded', String(expanded));
    document.body.toggleAttribute('data-mobile-menu-expanded', expanded);
    menuToggle?.setAttribute('aria-expanded', String(expanded));
    menuToggle?.setAttribute('aria-label', expanded ? 'Close menu' : 'Open menu');
    menuToggle?.querySelector('.open-icon')?.classList.toggle('hidden', expanded);
    menuToggle?.querySelector('.close-icon')?.classList.toggle('hidden', !expanded);
  };

  menuToggle?.addEventListener('click', () => {
    const starlightMenuBtn = document.querySelector('starlight-menu-button');
    const expanded = starlightMenuBtn?.getAttribute('aria-expanded') === 'true';
    setSidebarExpanded(!expanded);
  });

  // Homepage: trigger custom nav panel
  const homepageMenuToggle = document.getElementById('app-homepage-menu-toggle');
  const homepageMenu = document.getElementById('app-homepage-menu');

  const setHomepageMenuOpen = (open) => {
    if (!homepageMenu) return;
    homepageMenu.hidden = !open;
    document.body.toggleAttribute('data-mobile-menu-expanded', open);
    homepageMenuToggle?.setAttribute('aria-expanded', String(open));
    homepageMenuToggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    homepageMenuToggle?.querySelector('.open-icon')?.classList.toggle('hidden', open);
    homepageMenuToggle?.querySelector('.close-icon')?.classList.toggle('hidden', !open);
  };

  homepageMenuToggle?.addEventListener('click', () => {
    const isOpen = homepageMenuToggle.getAttribute('aria-expanded') === 'true';
    setHomepageMenuOpen(!isOpen);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      setSidebarExpanded(false);
      setHomepageMenuOpen(false);
    }
  });

  window.matchMedia('(min-width: 1280px)').addEventListener('change', (e) => {
    if (e.matches) {
      setSidebarExpanded(false);
      setHomepageMenuOpen(false);
    }
  });
</script>
